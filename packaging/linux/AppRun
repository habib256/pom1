#!/bin/bash
# AppRun pour POM1 - lance l'émulateur depuis un répertoire de données
# utilisateur en jouant le même découpage que la build macOS :
#   - les répertoires en lecture seule (roms, fonts, software, sketchs, dev, pic,
#     cassettes) sont exposés sous forme de liens symboliques pointant vers
#     l'AppDir,
#     ce qui permet aux probes cwd-relatives existants (ROM loader, fonts,
#     icone, mémoire par défaut, jaquettes K7) de résoudre correctement.
#   - les répertoires en lecture/écriture (sdcard, cfcard, ini) sont
#     amorcés depuis l'AppDir lors de la première exécution puis conservés
#     entre lancements dans $XDG_DATA_HOME/POM1.

set -e

HERE="$(dirname "$(readlink -f "${0}")")"
RES="${HERE}/usr/share/POM1"

XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
DATADIR="${XDG_DATA_HOME}/POM1"
mkdir -p "${DATADIR}"

# Read-only assets: relink à chaque lancement pour suivre les mises à jour
# de l'AppImage (l'utilisateur peut télécharger une nouvelle version sans
# vider son DATADIR).
for d in roms fonts software sketchs dev pic cassettes; do
    rm -f "${DATADIR}/${d}"
    if [ -d "${RES}/${d}" ]; then
        ln -s "${RES}/${d}" "${DATADIR}/${d}"
    fi
done

# Writable seeds: copiés au premier lancement, ensuite laissés à
# l'utilisateur (parties Sokoban sauvées sur la microSD virtuelle, fichiers
# ProDOS sur le CF, layouts ImGui par préset, etc.).
for d in sdcard cfcard; do
    if [ ! -e "${DATADIR}/${d}" ] && [ -d "${RES}/${d}" ]; then
        cp -r "${RES}/${d}" "${DATADIR}/${d}"
    fi
done
mkdir -p "${DATADIR}/ini"

# Writable CodeTank dev-cartridge dir: roms/ is a read-only squashfs symlink, so the
# TMS9918 asm/C DevBench cannot reflash roms/codetank/CODETANKDEV.rom in place.
# Point POM1 at a writable copy; it lazily seeds the Applesoft upper bank from the
# bundled read-only cartridge on the first flash.
mkdir -p "${DATADIR}/codetank"
export POM1_CODETANK_DEV_DIR="${DATADIR}/codetank"

export LD_LIBRARY_PATH="${HERE}/usr/lib:${LD_LIBRARY_PATH}"

# Bundled cc65 toolchain (if present): point the DevBench probe + cl65 runtime
# at it explicitly. POM1 also self-locates it exe-relative, but exporting these
# is robust against the chdir below and lets cl65 find its C runtime.
if [ -d "${RES}/cc65/bin" ]; then
    export POM1_CC65_DIR="${RES}/cc65/bin"
    [ -z "${CC65_HOME:-}" ] && export CC65_HOME="${RES}/cc65/share/cc65"
fi

cd "${DATADIR}"
exec "${HERE}/usr/bin/POM1" "$@"
