# Claude Code
/.claude

# Build output
build/
dist/

# CTest runtime artefacts (written by `ctest` under build/, but also spilled
# into the repo root by some IDE integrations)
Testing/

# Fichiers binaires de release (copie locale avant upload GitHub Releases)
releases/*.zip

# WASM build — keep only the POM1.* output files and shell template
build-appimage
build-debug
build-wasm/*
!build-wasm/POM1.*
!build-wasm/shell.html
!build-wasm/pic/

# Dear ImGui library (downloaded by setup_imgui.sh)
imgui/

# ImGui layout state (legacy global + per-preset directory)
imgui.ini
ini/

# clangd / other tool caches (local preprocessing index — machine-specific)
.cache/
compile_commands.json

# cc65 build intermediates (per-project Makefiles produce .o next to the .asm)
dev/projects/*/*.o

# Python bytecode / test caches (tools/ contains scripts run ad-hoc)
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# IDE / Editor
.vscode/
.idea/
.obsidian/
*.swp
*.swo
*~

# Quartus FPGA build artefacts (régénérés à chaque compilation)
fpga/db/
fpga/incremental_db/
fpga/output_files/
fpga/build_id.v
fpga/c5_pin_model_dump.txt
fpga/jtag.cdf
# Pour livrer un bitstream signé, whitelister explicitement, p.ex. :
# !fpga/output_files/AppleI_PLAB.rbf

# Stragglers Quartus typiques
*.qws
*.smsg
hps_isw_handoff/

# OS files
.DS_Store
Thumbs.db
C64Music/
