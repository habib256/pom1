# Claude Code
/.claude

# Build output
build/
dist/

# In-source CMake spill (canonical out-of-tree dir is build/ — some IDE
# integrations configure from the repo root and leave these behind)
/CMakeCache.txt
/CMakeFiles/
/cmake_install.cmake
/CTestTestfile.cmake
/Makefile
/POM1
/POM1.app/
/POM1.dSYM/
/basicc
/tests/CMakeFiles/
/tests/Makefile
/tests/cmake_install.cmake
/tests/CTestTestfile.cmake
/tests/klaus_6502_functional_test.bin
/tests/test_*
/src/third_party/libresidfp/CMakeFiles/
/src/third_party/libresidfp/Makefile
/src/third_party/libresidfp/cmake_install.cmake
/src/third_party/libresidfp/*.a
/tools/make_iec_fixture

# CTest runtime artefacts (written by `ctest` under build/, but also spilled
# into the repo root by some IDE integrations)
Testing/

# Fichiers binaires de release (copie locale avant upload GitHub Releases)
releases/*.zip

# WASM build under build-wasm/. Most CMake scratch is generated and ignored,
# but the DEPLOYED web app + the cc65-in-WASM DevBench toolchain ARE tracked:
# GitHub Pages serves these static files directly (it doesn't build), and CI's
# verify_wasm_cc65.sh (ci.yml) asserts the toolchain is committed. Rebuild with
# emcmake+emmake / tools/build_cc65_wasm.sh, then re-commit the refreshed set.
build-appimage
build-debug
build-wasm/*
!build-wasm/shell.html
!build-wasm/POM1.html
!build-wasm/POM1.js
!build-wasm/POM1.wasm
!build-wasm/POM1.data
!build-wasm/cc65_bench.js
!build-wasm/cc65_wasm.js
!build-wasm/pic
!build-wasm/cc65
# cc65 source checkout used by packaging/windows/build_cc65.ps1
build/cc65-src/

# Dear ImGui library (downloaded by setup_pom1.sh)
imgui/

# ImGui layout state (legacy global + per-preset directory)
imgui.ini
ini/

# clangd / other tool caches (local preprocessing index — machine-specific)
.cache/
compile_commands.json

# cc65 build intermediates (per-project Makefiles produce .o next to the .asm)
dev/projects/*/*.o

# cc65 build intermediates under sketchs/ (sketch Makefiles + ad-hoc cl65 runs
# drop .o/.map/.lst/.lbl next to the source; the canonical artefact lives under
# software/). Round-trip GOLDEN inputs stay tracked and are NOT matched here:
# sketchs/gen2/a2port_buzzard_bait/buzzard_bait.bin (da65 reference) and
# sketchs/gen2/game_pang/GEN2Pang.bin (only committed build of the game).
sketchs/**/*.o
sketchs/**/*.map
*.lst
*.lbl
# Specific in-tree intermediate .bin (rebuilt by `make` in their directory)
sketchs/gen2/demo_preshift/main.bin
sketchs/gen2/demo_sprengine/main.bin
sketchs/gen2/demo_sprengine/main_test.bin
sketchs/gen2/a2port_buzzard_bait/buzzard_bait.rebuilt.bin
sketchs/gen2/a2port_buzzard_bait/gen2_port.bin
# hello_gfx_text link outputs (portable demo — rebuilt by its Makefile)
sketchs/portable/hello_gfx_text/*.bin

# Python bytecode / test caches (tools/ contains scripts run ad-hoc)
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# IDE / Editor
.vscode/
.idea/
.obsidian/
*.swp
*.swo
*~

# Quartus FPGA build artefacts (régénérés à chaque compilation)
fpga/db/
fpga/incremental_db/
fpga/output_files/
fpga/build_id.v
fpga/c5_pin_model_dump.txt
fpga/jtag.cdf
# Pour livrer un bitstream signé, whitelister explicitement, p.ex. :
# !fpga/output_files/AppleI_PLAB.rbf

# Stragglers Quartus typiques
*.qws
*.smsg
hps_isw_handoff/

# OS files
.DS_Store
Thumbs.db
C64Music/

# Build artefacts under dev/ (cc65 objects + linker maps + library archives) —
# regenerated by build (e.g. dev/lib/gfx/gfx-*.lib via dev/lib/gfx/Makefile)
dev/**/*.o
dev/**/*.map
dev/**/*.lib
# Template scratch binaries — only the source (.c, Makefile) belongs in git
dev/_template_*/*.bin
# Per-project cl65 build outputs (deleted by `make clean`) — only the source and
# the canonical artefact under software/ belong in git, never the in-tree .bin.
dev/projects/**/*.bin
# Redundant flat binaries under software/ — the Wozmon .txt is the canonical form
software/**/*.bin
# Exception: SID tunes ship only as .bin (no .txt twin), so keep them tracked
!software/SOUND SID/**/*.bin
# NOTE: roms/codetank/CODETANKDEV.rom IS tracked (canonical cartridge — blank $FF
# flash slot + Applesoft TMS9918 upper bank). The DevBench rewrites its lower bank
# at runtime, but the clean image ships so the TMS9918 DevBench works out of the box.
roms/codetank/CODETANKDEV.rom
roms/codetank/CODETANKDEV.txt
