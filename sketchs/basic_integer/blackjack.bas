  312 PRINT "NOW I'M GETTING MAD"
      
  400 TAB 20: PRINT "WINNINGS: ";S: PRINT : GOTO 30
 1000 N=0: FOR I=1 TO 120:J= RND (52)+1:K= RND (52)+1:L=A(J):A(J)=A(K):A(K)=L: NEXT I:RETURN 
 2000 IF N>50 THEN GOSUB 1000:N=N+1:J=A(N)/4+1:K=A(N) MOD 4+1:C=J-J/10*(J-10): PRINT A$(J,J);B$(K,K);"  ";: RETURN 
      
 2020 GOSUB 2000:D=D+C+(C=1)*10:A2=A2+(C=1): IF D<22 OR A2=0 THEN RETURN :A2=A2-1:D=D-10: RETURN 
 2040 GOSUB 2000:P=P+C+(C=1)*10:A1=A1+(C=1): IF P<22 OR A1=0 THEN RETURN :A1=A1-1:P=P-10: RETURN 
