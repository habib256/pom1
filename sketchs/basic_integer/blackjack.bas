   20 INPUT "WELCOME TO 21.  YOUR NAME",C$: PRINT "OK, HERE WE GO ";C$;"."
   30 P=0:D=P:A1=P:A2=P: GOSUB 3000: IF B THEN 35: PRINT "END--STOPPED AT 30": END 
