   50 INPUT "HIT",D$: IF D$="N" OR D$="NO" THEN 60: IF D$#"Y" AND D$#"YES" THEN 40: TAB 11: GOSUB 2040: IF P<22 THEN 50: PRINT "BUSTED ";: GOTO 200
   60 PRINT : PRINT "MY CARDS: ";A$(E,E);B$(F,F);"  ";
